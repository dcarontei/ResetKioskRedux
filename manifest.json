{
    "manifest_version": 3,
    "name": "ResetKioskRedux",
    "version": "1.1",
    "description": "Resets the current tab to the browser home page after a configurable inactivity. For use with Firefox's Kiosk mode.",
    "icons": {
        "48": "icons/icon.png",
        "96": "icons/icon-96.png"
    },
    "permissions": [
        "storage",
        "tabs",
        "browserSettings",
        "alarms"
    ],
    "background": {
        "scripts": [
            "background.js"
        ],
        "service_worker": "background.js"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "browser_specific_settings": {
        "gecko": {
          "id": "resetkioskredux@thermaleconomy.com",
          "data_collection_permissions": {
            "required": ["none"]
          }
        }
      },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        }
    ]
}